<devicedata>
  <name>TP-Link Light</name>
  <version/>
  <manufacturer>TP-Link</manufacturer>
  <model>TP-Link Light</model>
  <creator>Derek Miller</creator>
  <small image_source="c4z">icons/device_sm.png</small>
  <large image_source="c4z">icons/device_lg.png</large>
  <control>lua_gen</control>
  <controlmethod>ip</controlmethod>
  <driver>DriverWorks</driver>
  <copyright>Copyright 2026 Finite Labs, LLC. All rights reserved.</copyright>
  <created>07/10/2026 12:00:00 PM</created>
  <modified/>
  <minimum_os_version>3.3.0</minimum_os_version>
  <composer_categories>
    <category>Lighting</category>
  </composer_categories>
  <conditionals/>
  <events/>
  <config>
    <script file="driver.lua" jit="1"/>
    <documentation file="www/documentation/index.html"/>
    <properties>
      <property>
        <name>Cloud</name>
        <type>LABEL</type>
        <default>Cloud Settings</default>
      </property>
      <!-- #ifdef DRIVERCENTRAL -->
      <property>
        <name>Cloud Status</name>
        <default/>
        <type>STRING</type>
        <readonly>true</readonly>
      </property>
      <!-- #endif -->
      <property>
        <name>Automatic Updates</name>
        <type>LIST</type>
        <items>
          <item>Off</item>
          <item>On</item>
        </items>
        <default>On</default>
      </property>
      <property>
        <name>Driver</name>
        <type>LABEL</type>
        <default>Driver Settings</default>
      </property>
      <property>
        <name>Driver Status</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Driver Version</name>
        <type>STRING</type>
        <default/>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Log Level</name>
        <type>LIST</type>
        <default>3 - Info</default>
        <items>
          <item>0 - Fatal</item>
          <item>1 - Error</item>
          <item>2 - Warning</item>
          <item>3 - Info</item>
          <item>4 - Debug</item>
          <item>5 - Trace</item>
          <item>6 - Ultra</item>
        </items>
      </property>
      <property>
        <name>Log Mode</name>
        <type>LIST</type>
        <default>Off</default>
        <items>
          <item>Off</item>
          <item>Print</item>
          <item>Log</item>
          <item>Print and Log</item>
        </items>
      </property>
      <property>
        <name>TP-Link Settings</name>
        <type>LABEL</type>
        <default>TP-Link Settings</default>
      </property>
      <property>
        <name>IP Address</name>
        <type>STRING</type>
        <default/>
        <description>IP address of the light device for direct control. Leave blank when this driver is bound to a TP-Link Outlet output. Use a DHCP reservation so it does not change.</description>
      </property>
      <property>
        <name>TP-Link Username</name>
        <type>STRING</type>
        <default/>
        <description>Email address of the TP-Link (Kasa/Tapo) account the device is bound to. Case sensitive. Only used for direct control.</description>
      </property>
      <property>
        <name>TP-Link Password</name>
        <type>STRING</type>
        <password>true</password>
        <default/>
        <description>Password of the TP-Link (Kasa/Tapo) account the device is bound to. Only used for direct control.</description>
      </property>
      <property>
        <name>Poll Rate (Seconds)</name>
        <type>RANGED_INTEGER</type>
        <minimum>2</minimum>
        <maximum>300</maximum>
        <default>5</default>
        <description>How often to poll the light state in direct mode.</description>
      </property>
    </properties>
    <commands/>
    <actions/>
  </config>
  <capabilities>
    <dimmer>True</dimmer>
    <set_level>True</set_level>
    <supports_target>True</supports_target>
    <supports_brightness_stop>True</supports_brightness_stop>
    <!--
      on_off, ramp_level, and supports_default_on are documented as
      "deprecated in 3.3.2" but Composer's test panel still gates UI
      elements on them: on_off enables the On/Off level buttons;
      ramp_level enables the Ramp button; supports_default_on enables
      the Default On preset editor including its Inactive Color picker.
    -->
    <on_off>True</on_off>
    <ramp_level>True</ramp_level>
    <supports_default_on>True</supports_default_on>
    <has_fixed_ramp_rate>False</has_fixed_ramp_rate>
    <fixed_ramp_rate>0</fixed_ramp_rate>
    <hide_proxy_properties>False</hide_proxy_properties>
    <hide_proxy_events>False</hide_proxy_events>
    <click_rates>True</click_rates>
    <hold_rates>True</hold_rates>
    <cold_start>False</cold_start>
    <has_leds>False</has_leds>
    <has_button_events>True</has_button_events>
    <supports_broadcast_scenes>False</supports_broadcast_scenes>
    <supports_multichannel_scenes>False</supports_multichannel_scenes>
    <reduced_als_support>False</reduced_als_support>
    <advanced_scene_support>True</advanced_scene_support>
    <load_group_support>False</load_group_support>
    <brightness_on_mode_preset>True</brightness_on_mode_preset>
    <brightness_on_mode_previous>True</brightness_on_mode_previous>
    <color_on_mode_fade>True</color_on_mode_fade>
    <color_on_mode_preset>True</color_on_mode_preset>
    <color_on_mode_previous>True</color_on_mode_previous>
    <multi_click>False</multi_click>
    <has_extras>False</has_extras>
    <disable_flash>False</disable_flash>
    <brightness_rate_min>0</brightness_rate_min>
    <brightness_rate_max>65535</brightness_rate_max>
    <click_rate_min>0</click_rate_min>
    <click_rate_max>65535</click_rate_max>
    <hold_rate_min>1000</hold_rate_min>
    <hold_rate_max>86400000</hold_rate_max>
    <supports_color>True</supports_color>
    <supports_color_correlated_temperature>True</supports_color_correlated_temperature>
    <supports_color_stop>True</supports_color_stop>
    <color_correlated_temperature_min>2000</color_correlated_temperature_min>
    <color_correlated_temperature_max>6500</color_correlated_temperature_max>
    <color_rate_behavior>1</color_rate_behavior>
    <color_rate_min>0</color_rate_min>
    <color_rate_max>65535</color_rate_max>
  </capabilities>
  <proxies>
    <proxy proxybindingid="5001" primary="True" name="TP-Link Light">light_v2</proxy>
  </proxies>
  <connections>
    <connection>
      <id>300</id>
      <facing>6</facing>
      <connectionname>On Button Link</connectionname>
      <type>1</type>
      <consumer>False</consumer>
      <audiosource>False</audiosource>
      <videosource>False</videosource>
      <linelevel>True</linelevel>
      <classes>
        <class>
          <classname>BUTTON_LINK</classname>
        </class>
      </classes>
    </connection>
    <connection>
      <id>301</id>
      <facing>6</facing>
      <connectionname>Toggle Button Link</connectionname>
      <type>1</type>
      <consumer>False</consumer>
      <audiosource>False</audiosource>
      <videosource>False</videosource>
      <linelevel>True</linelevel>
      <classes>
        <class>
          <classname>BUTTON_LINK</classname>
        </class>
      </classes>
    </connection>
    <connection>
      <id>302</id>
      <facing>6</facing>
      <connectionname>Off Button Link</connectionname>
