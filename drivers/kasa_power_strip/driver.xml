        </items>
      </property>
      <property>
        <name>Kasa Settings</name>
        <type>LABEL</type>
        <default>Kasa Settings</default>
      </property>
      <property>
        <name>IP Address</name>
        <type>STRING</type>
        <default/>
        <description>IP address of the Kasa device. Use a DHCP reservation so it does not change.</description>
      </property>
      <property>
        <name>TP-Link Username</name>
        <type>STRING</type>
        <default/>
        <description>Email address of the TP-Link (Kasa/Tapo) account the device is bound to. Case sensitive.</description>
      </property>
      <property>
        <name>TP-Link Password</name>
        <type>STRING</type>
        <password>true</password>
        <default/>
        <description>Password of the TP-Link (Kasa/Tapo) account the device is bound to.</description>
      </property>
      <property>
        <name>Poll Rate (Seconds)</name>
        <type>RANGED_INTEGER</type>
        <minimum>2</minimum>
        <maximum>300</maximum>
        <default>10</default>
        <description>How often to poll output states.</description>
      </property>
      <property>
        <name>Energy Poll Rate (Seconds)</name>
        <type>RANGED_INTEGER</type>
        <minimum>0</minimum>
        <maximum>300</maximum>
        <default>5</default>
        <description>How often to poll per-output power usage. 0 disables energy polling.</description>
      </property>
      <property>
        <name>Device Information</name>
        <type>LABEL</type>
        <default>Device Information</default>
      </property>
      <property>
        <name>Model</name>
        <type>STRING</type>
