    <properties>
      <property>
        <name>Cloud</name>
        <type>LABEL</type>
        <default>Cloud Settings</default>
      </property>
      <!-- #ifdef DRIVERCENTRAL -->
      <property>
        <name>Cloud Status</name>
        <default/>
